                  : <div style={{padding:'9px 12px',borderRadius:8,border:'1px solid #e2e8f0',background:'#f8fafc',fontSize:13,color:'#64748b'}}>{val}</div>
                }
              </div>
            ))}
            <button onClick={run} disabled={loading||fetching} style={{padding:'12px',borderRadius:10,background:loading?'#94a3b8':'#0f172a',color:'#fff',border:'none',cursor:loading?'wait':'pointer',fontSize:14,fontFamily:'inherit',fontWeight:700,display:'flex',alignItems:'center',justifyContent:'center',gap:8,transition:'all 0.2s'}}>
