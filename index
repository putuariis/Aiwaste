const interpolatePath = (path, totalSteps = 200) => {
  if (!path || path.length < 2) return path || [];
  const newPath = [];
  let totalDist = 0;
  const dists = [];
  for (let i = 0; i < path.length - 1; i++) {
    const d = Math.hypot(path[i+1][0]-path[i][0], path[i+1][1]-path[i][1]);
    dists.push(d); totalDist += d;
  }
  if (totalDist === 0) return path;
  for (let i = 0; i < path.length - 1; i++) {
    const steps = Math.max(1, Math.round((dists[i]/totalDist)*totalSteps));
    for (let s = 0; s < steps; s++) {
      const t = s/steps;
      newPath.push([path[i][0]+(path[i+1][0]-path[i][0])*t, path[i][1]+(path[i+1][1]-path[i][1])*t]);
    }
  }
  newPath.push(path[path.length-1]);
  return newPath;
};

const fetchOSRMRoute = async (waypoints, steps=300) => {
  try {
    const coords = waypoints.map(w=>`${w[1]},${w[0]}`).join(';');
    const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords}?overview=full&geometries=geojson`, {signal: AbortSignal.timeout(6000)});
    if (!res.ok) throw new Error('OSRM error');
    const data = await res.json();
    if (data.code === 'Ok') return interpolatePath(data.routes[0].geometry.coordinates.map(c=>[c[1],c[0]]), steps);
  } catch { /* fallback */ }
  return interpolatePath(waypoints, steps);
};

