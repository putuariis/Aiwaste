      </div>`;
      const icon = window.L.divIcon({className:'',html:truckHtml,iconSize:[22,22],iconAnchor:[11,11]});
      if (!markersRef.current[fleet.id]) {
        markersRef.current[fleet.id] = window.L.marker([fleet.lat,fleet.lng],{icon}).addTo(mapRef.current)
          .bindPopup(`<b>${fleet.plate}</b><br/>${fleet.driver}<br/><b>${fleet.speed} km/h</b>`);
        pathsRef.current[fleet.id] = window.L.polyline(fleet.path,{color,weight:3,opacity:0.55,dashArray:'6,10'}).addTo(mapRef.current);
      } else {
        markersRef.current[fleet.id].setLatLng([fleet.lat,fleet.lng]);
        markersRef.current[fleet.id].getPopup()?.setContent(`<b>${fleet.plate}</b><br/>${fleet.driver}<br/>Kecepatan: <b>${fleet.speed} km/h</b><br/>BBM: <b>${fmt(calcFuel(fleet.actualDistance,fleet.fuelEff))} L</b>`);
        pathsRef.current[fleet.id].setLatLngs(fleet.path);
      }
    });
  }, [fleets]);

  useEffect(() => {
    if (!selectedFleet || !mapRef.current || !markersRef.current[selectedFleet.id]) return;
    mapRef.current.panTo([selectedFleet.lat,selectedFleet.lng],{animate:true,duration:0.5});
    markersRef.current[selectedFleet.id].openPopup();
  }, [selectedFleet]);

  return (
    <div style={{background:'#fff',border:'1px solid #e2e8f0',borderRadius:12,overflow:'hidden',height:440,display:'flex',flexDirection:'column'}}>
