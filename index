            </button>
            <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
          </div>
          {/* Result */}
          <div style={{background:'#f8fafc',borderRadius:10,border:'1px solid #e2e8f0',padding:20,minHeight:320,display:'flex',flexDirection:'column',justifyContent:result?'flex-start':'center',alignItems:result?'stretch':'center'}}>
