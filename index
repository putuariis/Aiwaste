const AIChatPanel = ({ fleets, historicalData }) => {
  const [msgs, setMsgs] = useState([{role:'assistant',content:'Halo! Saya **EcoTrack AI Assistant**. Tanyakan apa saja tentang armada, emisi, atau efisiensi operasional Anda. Contoh: *"Armada mana yang paling boros BBM?"*'}]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const bottomRef = useRef(null);

  const suggestions = [
    'Armada mana yang paling boros BBM?',
    'Berikan rekomendasi penghematan emisi',
    'Analisis tren 30 hari terakhir',
    'Prediksi biaya operasional bulan depan',
  ];

  const buildContext = () => {
    const fleetSummary = fleets.map(f=>`${f.id}(${f.plate}): status=${f.status}, jarak=${fmt(f.actualDistance)}km, BBM=${fmt(calcFuel(f.actualDistance,f.fuelEff))}L, emisi=${fmt(calcCarbon(f.actualDistance,f.fuelEff))}kgCO2, health=${f.health}%`).join('\n');
    const totFuel30 = historicalData.reduce((a,d)=>a+d.totalFuel,0);
    const totViol = historicalData.reduce((a,d)=>a+d.violations,0);
    return `Kamu adalah asisten AI untuk sistem manajemen armada sampah kota Jakarta "EcoTrack AI". Data real-time:\n\nARMADA:\n${fleetSummary}\n\nTPA Bantar Gebang: kapasitas=${TPA_DATA.capacity}ton, terisi=${TPA_DATA.currentLoad}ton (${((TPA_DATA.currentLoad/TPA_DATA.capacity)*100).toFixed(1)}%), antrean=${TPA_DATA.queueCount} truk, tunggu=${TPA_DATA.waitTime}mnt\n\nHistoris 30 hari: total BBM=${totFuel30}L, pelanggaran=${totViol}x, total emisi=${Math.round(totFuel30*EMISSION_FACTOR)}kgCO2, biaya BBM=${fmtRp(totFuel30*14000)}\n\nJawab dalam bahasa Indonesia, singkat, padat, dan berikan rekomendasi konkret yang actionable. Gunakan angka spesifik dari data yang ada.`;
  };

  const send = async (text) => {
    const msg = text || input.trim();
    if (!msg) return;
    setInput('');
    const newMsgs = [...msgs, {role:'user',content:msg}];
    setMsgs(newMsgs);
    setLoading(true);
    try {
      const apiKey = ""; 
      const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
      
      const formattedContents = newMsgs.filter(m => m.role !== 'system').map(m => ({
        role: m.role === 'assistant' ? 'model' : 'user',
        parts: [{ text: m.content }]
      }));

      let res;
      let delay = 1000;
      for(let i=0; i<5; i++) {
        res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: formattedContents,
            systemInstruction: { parts: [{ text: buildContext() }] }
          })
        });
        if(res.ok) break;
        await new Promise(r => setTimeout(r, delay));
        delay *= 2;
      }

      if(!res.ok) throw new Error("API Error");
      const data = await res.json();
      const reply = data.candidates?.[0]?.content?.parts?.[0]?.text || 'Maaf, terjadi kesalahan atau tidak ada respons.';
      setMsgs(p => [...p, {role:'assistant',content:reply}]);
    } catch {
      setMsgs(p => [...p, {role:'assistant',content:'Koneksi ke AI bermasalah. Pastikan API key tersedia dan lingkungan mengizinkan request.'}]);
    }
    setLoading(false);
  };

  useEffect(()=>{ bottomRef.current?.scrollIntoView({behavior:'smooth'}); },[msgs,loading]);

  const renderMsg = (text) => {
    return text.split(/(\*\*[^*]+\*\*)/g).map((part,i)=>
      part.startsWith('**')&&part.endsWith('**')
        ? <strong key={i}>{part.slice(2,-2)}</strong>
        : part
    );
  };

  return (
    <div style={{display:'flex',flexDirection:'column',height:'100%',background:'#fff',border:'1px solid #e2e8f0',borderRadius:12,overflow:'hidden'}}>
      <div style={{padding:'12px 16px',borderBottom:'1px solid #f1f5f9',display:'flex',alignItems:'center',gap:8,background:'linear-gradient(135deg,#0f172a,#1e293b)'}}>
        <div style={{width:32,height:32,borderRadius:'50%',background:'#10b981',display:'flex',alignItems:'center',justifyContent:'center',color:'#fff'}}>
          <Icons.Bot/>
        </div>
        <div>
          <div style={{fontWeight:700,color:'#fff',fontSize:13}}>EcoTrack AI Assistant</div>
          <div style={{fontSize:10,color:'#10b981'}}>● Online – Powered by Gemini</div>
        </div>
      </div>

      <div style={{flex:1,overflowY:'auto',padding:16,display:'flex',flexDirection:'column',gap:12}}>
        {msgs.map((m,i)=>(
          <div key={i} style={{display:'flex',justifyContent:m.role==='user'?'flex-end':'flex-start'}}>
            <div style={{maxWidth:'85%',padding:'10px 14px',borderRadius:m.role==='user'?'16px 16px 4px 16px':'16px 16px 16px 4px',background:m.role==='user'?'#0f172a':'#f8fafc',border:m.role==='user'?'none':'1px solid #e2e8f0',color:m.role==='user'?'#fff':'#0f172a',fontSize:13,lineHeight:1.6,whiteSpace:'pre-wrap'}}>
              {renderMsg(m.content)}
            </div>
          </div>
        ))}
        {loading && (
          <div style={{display:'flex',gap:4,padding:'10px 14px',background:'#f8fafc',border:'1px solid #e2e8f0',borderRadius:'16px 16px 16px 4px',width:'fit-content'}}>
            {[0,1,2].map(i=><div key={i} style={{width:6,height:6,borderRadius:'50%',background:'#94a3b8',animation:`bounce 0.8s ${i*0.15}s infinite alternate`}}/>)}
          </div>
        )}
        <div ref={bottomRef}/>
      </div>

      <div style={{padding:'8px 12px',borderTop:'1px solid #f1f5f9'}}>
        <div style={{display:'flex',flexWrap:'wrap',gap:6,marginBottom:10}}>
          {suggestions.map((s,i)=>(
            <button key={i} onClick={()=>send(s)} style={{fontSize:10,padding:'4px 10px',borderRadius:20,border:'1px solid #e2e8f0',background:'#f8fafc',cursor:'pointer',color:'#475569',fontFamily:'inherit'}}>
              {s}
            </button>
          ))}
        </div>
        <div style={{display:'flex',gap:8}}>
          <input value={input} onChange={e=>setInput(e.target.value)} onKeyDown={e=>e.key==='Enter'&&!e.shiftKey&&send()} placeholder="Tanya AI tentang armada..." style={{flex:1,padding:'9px 14px',borderRadius:10,border:'1px solid #e2e8f0',fontSize:13,fontFamily:'inherit',outline:'none'}}/>
          <button onClick={()=>send()} disabled={loading} style={{padding:'9px 14px',borderRadius:10,background:'#0f172a',color:'#fff',border:'none',cursor:'pointer',display:'flex',alignItems:'center',gap:5,fontFamily:'inherit',fontSize:13}}>
            <Icons.Send/> Kirim
          </button>
        </div>
      </div>
      <style>{`@keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-6px)}} @keyframes ping{0%,100%{opacity:1}50%{opacity:0.4}}`}</style>
    </div>
  );
};

