      chartInstance.current = new window.Chart(chartRef.current,{
        type:chartType==='violations'?'bar':'line',
        data:{labels,datasets},
        options:{
          responsive:true,maintainAspectRatio:false,
          plugins:{legend:{display:true,position:'top',labels:{boxWidth:10,padding:15,font:{size:11}}},tooltip:{mode:'index',intersect:false}},
