export default function App() {
  const [active, setActive] = useState('dashboard');
  const [fleets, setFleets] = useState(INITIAL_FLEETS);
  const [selected, setSelected] = useState(null);
  const [time, setTime] = useState(new Date().toLocaleTimeString('id-ID'));
  const [routesLoaded, setRoutesLoaded] = useState(false);
  const animRef = useRef(null);

  // Load real OSRM routes
  useEffect(()=>{
    let mounted=true;
    (async()=>{
      const updated = await Promise.all(INITIAL_FLEETS.map(async f=>{
        const path = await fetchOSRMRoute(f.waypoints,300);
        return {...f, path, lat:path[0][0], lng:path[0][1], progress:0};
      }));
      if(mounted){setFleets(updated);setRoutesLoaded(true);}
    })();
    return()=>{mounted=false;};
  },[]);

  // Animation loop with Active/Idle time calculation
  useEffect(()=>{
    if(!routesLoaded)return;
    const tick=()=>{
      setTime(new Date().toLocaleTimeString('id-ID'));
      setFleets(prev=>prev.map(f=>{
        // Update idle and active metrics tracking
        const isIdle = f.status === 'broken' || f.progress >= f.path.length - 1 || f.speed === 0;
        const newActiveTime = (f.activeTime || 0) + (isIdle ? 0 : 1);
        const newIdleTime = (f.idleTime || 0) + (isIdle ? 1 : 0);

        if(isIdle) return { ...f, speed: 0, activeTime: newActiveTime, idleTime: newIdleTime };

        const np=Math.min(f.progress+1,f.path.length-1);
        const dist=(np/f.path.length)*f.optimalDistance*(f.status==='deviation'?1.55:1.0);
        return {
          ...f, 
          progress: np, 
          lat: f.path[np][0], 
          lng: f.path[np][1], 
          actualDistance: parseFloat(dist.toFixed(2)),
          activeTime: newActiveTime,
          idleTime: newIdleTime
        };
      }));
      animRef.current=setTimeout(tick,1000);
    };
    animRef.current=setTimeout(tick,1000);
    return()=>clearTimeout(animRef.current);
  },[routesLoaded]);

  const iotAlerts = fleets.filter(f=>f.status==='deviation').length;

  return (
    <div style={{display:'flex',height:'100vh',background:'#f8fafc',fontFamily:'-apple-system,BlinkMacSystemFont,"Segoe UI",system-ui,sans-serif'}}>
      <Sidebar active={active} setActive={setActive} alerts={iotAlerts}/>
      <div style={{marginLeft:220,flex:1,display:'flex',flexDirection:'column',overflow:'hidden'}}>
        <Topbar active={active} time={time}/>
        <main style={{flex:1,overflowY:'auto',padding:20}}>
          <div style={{maxWidth:1200,margin:'0 auto'}}>
            {active==='dashboard'   && <DashboardView fleets={fleets} selectedFleet={selected} setSelectedFleet={setSelected} routesLoaded={routesLoaded}/>}
            {active==='history'     && <HistoryView/>}
            {active==='iot'         && <IoTView/>}
            {active==='simulator'   && <SimulatorView fleets={fleets}/>}
            {active==='maintenance' && <MaintenanceView/>}
            {active==='analytics'   && <AnalyticsView fleets={fleets}/>}
            {active==='carbon'      && <CarbonView fleets={fleets}/>}
            {active==='leaderboard' && <LeaderboardView/>}
            {active==='ai'          && (
              <div style={{height:'calc(100vh - 120px)'}}>
                <AIChatPanel fleets={fleets} historicalData={HISTORICAL}/>
              </div>
            )}
          </div>
        </main>
      </div>
    </div>
  );
}
