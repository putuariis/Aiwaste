  const [fleetCond, setFleetCond] = useState('1 Armada Rusak (TRK-003)');
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);
  const [liveMode, setLiveMode] = useState(false);
  const [fetching, setFetching] = useState(false);

  const fetchLive = async () => {
    setFetching(true);
    try {
      const res = await fetch('https://api.open-meteo.com/v1/forecast?latitude=-6.2088&longitude=106.8456&current_weather=true');
      const data = await res.json();
      const code = data.current_weather.weathercode;
      const h = new Date().getHours();
      setWeather(code>=71?'Hujan Badai':code>=51?'Hujan Sedang':'Cerah / Berawan');
      setTraffic((h>=7&&h<=9)||(h>=16&&h<=19)?'Macet Parah (Jalur Utama Merah)':h>=10&&h<=15?'Padat Merayap':'Lancar');
    } catch { setWeather('Data API Tidak Tersedia'); }
    setFetching(false);
  };

  useEffect(()=>{ if(liveMode)fetchLive(); },[liveMode]);

  const run = () => {
    setLoading(true); setResult(null);
    setTimeout(()=>{
      const timeSaved = traffic.includes('Macet')&&weather.includes('Hujan')?2.2:traffic.includes('Macet')?1.5:0.8;
      const fuelSaved = timeSaved*8.5;
      const carbonSaved = fuelSaved*EMISSION_FACTOR;
      setResult({ timeSaved, fuelSaved, carbonSaved, cost:fuelSaved*14000, route: traffic.includes('Macet')?'JORR 2 + Tol Becakayu':'Rute Normal Dioptimasi', fleetActive: fleetCond.includes('Rusak')?3:4 });
      setLoading(false);
    },2200);
  };

  return (
    <div style={{display:'flex',flexDirection:'column',gap:16}}>
      <div style={{background:'#fff',border:'1px solid #e2e8f0',borderRadius:12,padding:24}}>
        <div style={{fontWeight:700,fontSize:16,color:'#0f172a',marginBottom:4}}>AI Scheduling Simulator</div>
        <div style={{fontSize:12,color:'#64748b',marginBottom:20}}>Simulasi optimasi rute dan penjadwalan berbasis multi-variabel indikator real-time.</div>
        <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:20}}>
          {/* Inputs */}
          <div style={{display:'flex',flexDirection:'column',gap:14}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',background:'#f8fafc',borderRadius:10,padding:'10px 14px',border:'1px solid #e2e8f0'}}>
